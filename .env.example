# Local defaults. `bun run ports:write` rewrites .env with worktree-specific
# PORT, POSTGRES_PORT, COMPOSE_PROJECT_NAME, and DATABASE_URL values.
PORT=4321
POSTGRES_PORT=5432
POSTGRES_DB=house_calendar
POSTGRES_USER=house_calendar
POSTGRES_PASSWORD=house_calendar
DATABASE_URL=postgresql://house_calendar:house_calendar@127.0.0.1:5432/house_calendar

# Optional app config path override. By default the app reads config/config.json
# when present and falls back to config/config.example.json.
HOUSE_CALENDAR_CONFIG_PATH=

# Calendar feed secrets referenced by config/config.example.json or a private
# config/config.json. Do not commit real ICS URLs.
ICS_URL_TOKYO=
ICS_URL_TAIWAN=

# Optional viewer password when a site uses password-gated access.
VIEWER_PASSWORD=

# Optional calendar sync cache TTL override.
ICS_SYNC_TTL_MINUTES=

# Optional admin login protection settings.
ADMIN_LOGIN_IDENTIFIER_PEPPER=
ADMIN_LOGIN_IP_HEADER=
ADMIN_TURNSTILE_SITE_KEY=
ADMIN_TURNSTILE_SECRET_KEY=

# Optional regression-check credentials. Keep unset unless running a local or
# deployment smoke check that should verify a real admin login.
REGRESSION_ADMIN_EMAIL=
REGRESSION_ADMIN_PASSWORD=
